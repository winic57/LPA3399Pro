diff --git a/drivers/pci/controller/pcie-rockchip-host.c b/drivers/pci/controller/pcie-rockchip-host.c
index ee1822c..f2c6f39 100644
--- a/drivers/pci/controller/pcie-rockchip-host.c
+++ b/drivers/pci/controller/pcie-rockchip-host.c
@@ -285,12 +285,20 @@ static int rockchip_pcie_host_init_port(struct rockchip_pcie *rockchip)
 	struct device *dev = rockchip->dev;
 	int err, i = MAX_LANE_NUM;
 	u32 status;
+	int attempt_counter = 0;
 
+err_retry_init:
 	gpiod_set_value_cansleep(rockchip->perst_gpio, 0);
 
 	err = rockchip_pcie_init_port(rockchip);
-	if (err)
+	if (err) {
+		if (attempt_counter++ < 5) {
+			dev_warn(dev, "PCIe init port failed, retrying (%d/5)...\n", attempt_counter);
+			msleep(100);
+			goto err_retry_init;
+		}
 		return err;
+	}
 
 	/* Fix the transmitted FTS count desired to exit from L0s. */
 	status = rockchip_pcie_read(rockchip, PCIE_CORE_CTRL_PLC1);
@@ -325,6 +333,18 @@ static int rockchip_pcie_host_init_port(struct rockchip_pcie *rockchip)
 				 500 * USEC_PER_MSEC);
 	if (err) {
 		dev_err(dev, "PCIe link training gen1 timeout!\n");
+		if (attempt_counter++ < 5) {
+			dev_warn(dev, "Retrying PCIe link training (%d/5)...\n", attempt_counter);
+			i = MAX_LANE_NUM;
+			while (i--)
+				phy_power_off(rockchip->phys[i]);
+			i = MAX_LANE_NUM;
+			while (i--)
+				phy_exit(rockchip->phys[i]);
+			i = MAX_LANE_NUM;
+			msleep(200);
+			goto err_retry_init;
+		}
 		goto err_power_off_phy;
 	}
 
