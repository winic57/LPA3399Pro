From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Antigravity <antigravity@example.com>
Date: Thu, 25 Jun 2026 22:45:00 +0800
Subject: [PATCH] PCI: rockchip: Add retry logic for PCIe link training and init port

The PCIe link training to the RK1808 NPU on LPA3399Pro is unstable and
often times out during Gen1 training. Adding a retry loop (up to 5 attempts)
to re-initialize the port and retry link training solves the cold boot timeout
and allows the link to successfully train.

Signed-off-by: Antigravity <antigravity@example.com>
---
 drivers/pci/controller/pcie-rockchip-host.c | 22 +++++++++++++++++++-
 1 file changed, 21 insertions(+), 1 deletion(-)

diff --git a/drivers/pci/controller/pcie-rockchip-host.c b/drivers/pci/controller/pcie-rockchip-host.c
index 8e452a2221ba..ad121bba8f45 100644
--- a/drivers/pci/controller/pcie-rockchip-host.c
+++ b/drivers/pci/controller/pcie-rockchip-host.c
@@ -282,12 +282,22 @@
 static int rockchip_pcie_host_init_port(struct rockchip_pcie *rockchip)
 {
 	struct device *dev = rockchip->dev;
 	int err, i = MAX_LANE_NUM;
 	u32 status;
+	int attempt_counter = 0;
 
+err_retry_init:
 	gpiod_set_value_cansleep(rockchip->perst_gpio, 0);
 
 	err = rockchip_pcie_init_port(rockchip);
-	if (err)
-		return err;
+	if (err) {
+		if (attempt_counter++ < 5) {
+			dev_warn(dev, "PCIe init port failed, retrying (%d/5)...\n", attempt_counter);
+			msleep(100);
+			goto err_retry_init;
+		}
+		return err;
+	}
 
 	/* Fix the transmitted FTS count desired to exit from L0s. */
 	status = rockchip_pcie_read(rockchip, PCIE_CORE_CTRL_PLC1);
@@ -324,6 +334,16 @@ static int rockchip_pcie_host_init_port(struct rockchip_pcie *rockchip)
 				 500 * USEC_PER_MSEC);
 	if (err) {
 		dev_err(dev, "PCIe link training gen1 timeout!\n");
-		goto err_power_off_phy;
+		if (attempt_counter++ < 5) {
+			dev_warn(dev, "Retrying PCIe link training (%d/5)...\n", attempt_counter);
+			i = MAX_LANE_NUM;
+			while (i--)
+				phy_power_off(rockchip->phys[i]);
+			i = MAX_LANE_NUM;
+			while (i--)
+				phy_exit(rockchip->phys[i]);
+			i = MAX_LANE_NUM;
+			msleep(200);
+			goto err_retry_init;
+		}
+		goto err_power_off_phy;
 	}
 
 	if (rockchip->link_gen == 2) {
-- 
