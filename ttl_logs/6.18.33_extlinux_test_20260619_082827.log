def write_reg(fd, base, offset, value):
    """Write a 32-bit register via /dev/mem."""
    page_size = 4096
    page_base = base & ~(page_size - 1)

    page_offset = base + offset - page_base
    mm = mmap.mmap(fd, page_size, offset=page_base)
    mm[page_offset:page_offset+4] = struct.pack('<I', value)
    mm.close()

def read_reg_addr(fd, addr):
    """Read a 32-bit register at absolute address."""
    page_size = 4096
    page_base = addr & ~(page_size - 1)
    page_offset = addr - page_base
    mm = mmap.mmap(fd, page_size, offset=page_base)
    val = struct.unpack('<I', mm[page_offset:page_offset+4])[0]
    mm.close()
    return val

def write_reg_addr(fd, addr, value):
    """Write a 32-bit register at absolute address."""
    page_size = 4096
    page_base = addr & ~(page_size - 1)
    page_offset = addr - page_base
    mm = mmap.mmap(fd, page_size, offset=page_base)
    mm[page_offset:page_offset+4] = struct.pack('<I', value)

    mm.close()

fd = os.open('/dev/mem', os.O_RDWR | os.O_SYNC)

# RK3399 CRU base
CRU_BASE = 0xff760000
# CLKGATE_CON(31) = 0x300 + 31*4 = 0x37c
CLKGATE_CON31 = CRU_BASE + 0x37c

# GMAC base
GMAC_BASE = 0xfe300000
DMA_BUS_MODE_ADDR = GMAC_BASE + 0x1000  # DMA_BUS_MODE = 0x1000

print("=== CRU Clock Gate Diagnostic ===")
print()

# Read CLKGATE_CON(31) - contains mac_clk_rx (bit14) and mac_clk_tx (bit15)
gate31 = read_reg_addr(fd, CLKGATE_CON31)
print(f"CRU CLKGATE_CON(31) [0xff76037c] = 0x{gate31:08x}")
print(f"  bit14 (mac_clk_rx / SCLK_MAC_RX): {'ENABLED (0)' if not (gate31 & (1<<14)) else 'DISABLED (1)'}")
print(f"  bit15 (mac_clk_tx / SCLK_MAC_TX): {'ENABLED (0)' if not (gate31 & (1<<15)) else 'DISABLED (1)'}")
print()

# Read other relevant CLKGATE_CON registers
# SCLK_MAC is in a different gate - let's find it
# From clk-rk3399.c: GATE(ACLK_GMAC, ..., RK3399_CLKGATE_CON(32), ...)
#                    GATE(PCLK_GMAC, ..., RK3399_CLKGATE_CON(32), ...)
gate32 = read_reg_addr(fd, CRU_BASE + 0x380)
print(f"CRU CLKGATE_CON(32) [0xff760380] = 0x{gate32:08x}")

# Also check CLKGATE_CON(31) for SCLK_MAC gate
# SCLK_MAC might be in a COMPOSITE with its own gate
# Let's also check the MUX register for clk_rmii_src
# MUX(SCLK_RMII_SRC, ..., RK3399_CLKSEL_CON(20), ...)
clk_sel20 = read_reg_addr(fd, CRU_BASE + 0x110 + 20*4)  # CLKSEL_CON(20)
print(f"CRU CLKSEL_CON(20) [0xff7601a0] = 0x{clk_sel20:08x}")

# Read DMA_BUS_MODE
dma_bus_mode = read_reg_addr(fd, DMA_BUS_MODE_ADDR)
print(f"\nDMA_BUS_MODE [0xfe301000] = 0x{dma_bus_mode:08x}")
print(f"  SWR (bit0): {dma_bus_mode & 1}")
print()

# Read GMAC_MII_ADDR to check MDIO state
mii_addr = read_reg_addr(fd, GMAC_BASE + 0x10)
print(f"GMAC_MII_ADDR [0xfe300010] = 0x{mii_addr:08x}")

# Read PHY BMSR (reg 0x01) via MDIO
# DWMAC1000 MDIO format: bit0=BUSY, bit1=GWRITE, bits2-5=clk_csr, bits6-10=reg, bits11-15=phy
def mdio_read(phy_addr, reg_addr):
    """Read PHY register via GMAC MDIO."""
    # Wait for not busy
    for _ in range(1000):
        val = read_reg_addr(fd, GMAC_BASE + 0x10)
        if not (val & 1):  # bit0 = BUSY
            break
    else:
        return -1
    # Build MDIO read command: phy at bits 11-15, reg at bits 6-10, clk_csr=3 at bits 2-5, no write bit
    cmd = (phy_addr << 11) | (reg_addr << 6) | (3 << 2) | 0  # read=0
    write_reg_addr(fd, GMAC_BASE + 0x10, cmd)
    # Wait for completion
    for _ in range(1000):
        val = read_reg_addr(fd, GMAC_BASE + 0x10)
        if not (val & 1):  # bit0 = BUSY cleared
            break
    else:

        return -1
    data = read_reg_addr(fd, GMAC_BASE + 0x14)
    return data & 0xFFFF

# Read PHY ID to confirm MDIO works
phy_id1 = mdio_read(0, 0x02)
phy_id2 = mdio_read(0, 0x03)
print(f"\nPHY regs via MDIO:")
