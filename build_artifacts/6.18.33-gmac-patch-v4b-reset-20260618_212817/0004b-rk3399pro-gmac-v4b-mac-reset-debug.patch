+static void rk3399pro_gmac_reset_cycle(struct rk_priv_data *bsp_priv,
+				       const char *stage)
+{
+	struct device *dev = bsp_priv->dev;
+	int ret;
+
+	if (!bsp_priv->stmmac_rst_dbg) {
+		dev_info(dev, "v4b-reset %s: no stmmaceth reset controller\n",
+			 stage);
+		return;
+	}
+
+	dev_info(dev, "v4b-reset %s: assert stmmaceth\n", stage);
+	ret = reset_control_assert(bsp_priv->stmmac_rst_dbg);
+	if (ret)
+		dev_warn(dev, "v4b-reset %s: assert failed ret=%d\n",
+			 stage, ret);
+
+	usleep_range(10000, 20000);
+
+	dev_info(dev, "v4b-reset %s: deassert stmmaceth\n", stage);
+	ret = reset_control_deassert(bsp_priv->stmmac_rst_dbg);
+	if (ret)
+		dev_warn(dev, "v4b-reset %s: deassert failed ret=%d\n",
+			 stage, ret);
+
+	msleep(50);
+	dev_info(dev, "v4b-reset %s: done\n", stage);
+}
