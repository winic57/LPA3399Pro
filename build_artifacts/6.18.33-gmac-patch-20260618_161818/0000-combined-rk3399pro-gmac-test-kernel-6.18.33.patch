+static void rk3399pro_test_prepare(struct rk_priv_data *bsp_priv)
+{
+	if (bsp_priv->ops != &rk3399_ops)
+		return;
+
+	if (bsp_priv->phy_iface != PHY_INTERFACE_MODE_RGMII &&
+	    bsp_priv->phy_iface != PHY_INTERFACE_MODE_RGMII_ID &&
+	    bsp_priv->phy_iface != PHY_INTERFACE_MODE_RGMII_RXID &&
+	    bsp_priv->phy_iface != PHY_INTERFACE_MODE_RGMII_TXID)
+		return;
+
+	if (bsp_priv->integrated_phy)
+		return;
+
+	if (!bsp_priv->clock_input) {
+		bsp_priv->clock_input = true;
+		dev_info(bsp_priv->dev,
+			 "rk3399pro test workaround: forcing clock_input=true for external RGMII PHY\n");
+	}
+}
