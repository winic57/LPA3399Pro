+/* v4c: fix_soc_reset callback — instrumented DMA reset to diagnose
+ * why DMA_BUS_MODE SWR bit never clears.  Replaces default dwmac_dma_reset().
+ * Dumps register state before/after SWR write and during polling to reveal:
+ *  - Whether the write reaches hardware (value changes after writel)
+ *  - Whether SWR is stuck (polls never see it clear)
+ *  - Whether SWR clears immediately (reset succeeds, problem is elsewhere)
+ */
+static int rk3399pro_fix_soc_reset(struct stmmac_priv *priv)
+{
+	void __iomem *ioaddr = priv->ioaddr;
+	u32 value;
+	int i;
+
+	value = readl(ioaddr + DMA_BUS_MODE);
+	netdev_info(priv->dev, "v4c: DMA_BUS_MODE before reset: 0x%08x (SWR=%d)\n",
+		    value, value & DMA_BUS_MODE_SFT_RESET ? 1 : 0);
+
+	value |= DMA_BUS_MODE_SFT_RESET;
+	writel(value, ioaddr + DMA_BUS_MODE);
+
+	value = readl(ioaddr + DMA_BUS_MODE);
+	netdev_info(priv->dev, "v4c: DMA_BUS_MODE after SWR write: 0x%08x (SWR=%d)\n",
+		    value, value & DMA_BUS_MODE_SFT_RESET ? 1 : 0);
+
+	for (i = 0; i < 20; i++) {
+		udelay(10000);
+		value = readl(ioaddr + DMA_BUS_MODE);
+		if (!(value & DMA_BUS_MODE_SFT_RESET)) {
+			netdev_info(priv->dev,
+				    "v4c: SWR cleared after %d ms: 0x%08x\n",
+				    (i + 1) * 10, value);
+			return 0;
+		}
+		netdev_info(priv->dev,
+			    "v4c: poll [%d/20]: 0x%08x (SWR still set)\n",
+			    i + 1, value);
+	}
+
+	netdev_err(priv->dev, "v4c: SWR stuck after 200ms: 0x%08x\n", value);
+	return -ETIMEDOUT;
+}

